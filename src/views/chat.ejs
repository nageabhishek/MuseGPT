<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MuseGPT</title>

    <link rel="stylesheet" href="/css/chat.css">
</head>
<body>

<div class="container">

    <!-- Sidebar -->

    <aside class="sidebar">

        <div class="logo">

            MuseGPT

        </div>


        <button class="new-chat" id="newChatBtn">

            + New Chat

        </button>



        <div class="chat-history" id="chatHistory">

        </div>




        <div class="logout">

            <a href="/logout">

                Logout

            </a>

        </div>

    </aside>






    <!-- Main Chat -->

    <main class="main">


        <div class="welcome" id="welcome">

            <h1>

                How can I help you today?

            </h1>

            <p>

                MuseGPT is ready to assist you.

            </p>

        </div>




        <div class="messages" id="messages">

        </div>






        <div class="input-box">

            <textarea

                id="messageInput"

                placeholder="Ask MuseGPT anything..."

                rows="1">

            </textarea>


            <button id="sendBtn">

                ↑

            </button>


        </div>


    </main>


</div>



<!-- Scripts -->

<script src="/socket.io/socket.io.js"></script>

<script src="/js/chat.js"></script>


</body>
</html>